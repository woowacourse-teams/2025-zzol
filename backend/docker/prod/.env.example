# Docker Registry (e.g. ghcr.io/your-username)
REGISTRY=ghcr.io/your-username

# Blue-Green 이미지 태그 (deploy script가 배포 시 직접 수정)
BLUE_IMAGE_TAG=placeholder
GREEN_IMAGE_TAG=placeholder

# JVM Memory Configuration
# Docker 메모리 제한: 6GB
# 권장 설정: -Xms4200m -Xmx4200m (Docker limit의 70%)
JAVA_OPTS='-Xms4200m -Xmx4200m'

# Database Password
DB_PASSWORD=change_me

# Observability Configuration
TEMPO_URL=http://tempo:4318/v1/traces
TRACE_SAMPLING_PROBABILITY=0.1

# 표준국어대사전 오픈 API (https://stdict.korean.go.kr/openapi/openApiInfo.do)
STDICT_API_KEY=change_me
