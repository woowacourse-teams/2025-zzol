{
  "name": "@zzol/api-mcp",
  "version": "0.1.0",
  "description": "MCP server for the zzol HTTP (OpenAPI) + WebSocket (STOMP) API tools",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/server.js",
  "bin": {
    "api-mcp": "dist/server.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.0.4",
    "@stomp/stompjs": "^7.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^20.12.7",
    "@types/ws": "^8.5.12",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "msw": "^2.4.9",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.11.0",
    "vitest": "^2.0.5"
  }
}
